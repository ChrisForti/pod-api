# Server
SERVER_PORT=3001

# Printful — NEVER expose these to the client
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=

# AWS S3 (or Cloudflare R2 — see notes below)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ── Cloudflare R2 (alternative to S3) ──────────────────────────────────
# If using R2, set CF_ACCOUNT_ID and R2_PUBLIC_DOMAIN instead of AWS_REGION.
# CF_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_PUBLIC_DOMAIN=https://your-r2-bucket.your-domain.com

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/pod_db

# Frontend origin — used for CORS (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development
